FROM postgres:16
RUN mkdir -p /scripts \
    && printf '#!/bin/bash\nset -euo pipefail\n\nPGDATA="${PGDATA:-/var/lib/postgresql/data}"\nPRIMARY_HOST="postgres"\nPRIMARY_PORT="5432"\nREPL_USER="replicator"\n\nmkdir -p "${PGDATA}"\nchmod 700 "${PGDATA}"\n\nuntil pg_isready -h "${PRIMARY_HOST}" -p "${PRIMARY_PORT}" >/dev/null 2>&1; do\n  echo "waiting for primary postgres..."\n  sleep 2\ndone\n\nif [ ! -s "${PGDATA}/PG_VERSION" ]; then\n  rm -rf "${PGDATA:?}/"*\n\n  until pg_basebackup \\\n    -h "${PRIMARY_HOST}" \\\n    -p "${PRIMARY_PORT}" \\\n    -U "${REPL_USER}" \\\n    -D "${PGDATA}" \\\n    -R \\\n    -Fp \\\n    -Xs \\\n    -P; do\n    echo "waiting for replication user/publication on primary..."\n    rm -rf "${PGDATA:?}/"*\n    sleep 2\n  done\n\n  printf "recovery_min_apply_delay = '"'"'1min'"'"'\nhot_standby = on\n" >> "${PGDATA}/postgresql.auto.conf"\nfi\n\nexec postgres -D "${PGDATA}"\n' > /scripts/bootstrap-replica.sh \
    && chmod +x /scripts/bootstrap-replica.sh
